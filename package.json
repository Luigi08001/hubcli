{
  "name": "@revfleet/hscli",
  "version": "0.8.9",
  "description": "Agentic HubSpot CLI + MCP server. Covers ~all documented public endpoints (1180 across 55+ command domains). Reachability is tier/scope/auth-model gated — UI-only surfaces and deprecated APIs excluded. Enterprise safety rails, self-hosted.",
  "type": "module",
  "bin": {
    "hscli": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "HSCLI_ENABLE_SANDBOX_CONTRACT=1 vitest run tests/contract.sandbox.test.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "release:checksums": "node scripts/release-checksums.mjs",
    "audit": "npm audit --audit-level=high",
    "release:verify": "npm run typecheck && npm run lint && npm test && npm run audit && npm run build && npm run release:checksums && shasum -a 256 -c release/checksums.sha256",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "hubspot",
    "cli",
    "crm",
    "mcp",
    "mcp-server",
    "ai-agents",
    "claude",
    "anthropic",
    "hubspot-api",
    "crm-automation",
    "dev-tools",
    "audit"
  ],
  "license": "MIT",
  "homepage": "https://github.com/revfleet/hscli#readme",
  "bugs": {
    "url": "https://github.com/revfleet/hscli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revfleet/hscli.git"
  },
  "author": "revfleet",
  "exports": {
    ".": "./dist/cli.js",
    "./plugins": "./dist/core/plugins.js",
    "./http": "./dist/core/http.js",
    "./output": "./dist/core/output.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs/*.md",
    "docs/TUTORIALS/*.md",
    "docs/POLICY_EXAMPLE.json",
    "docs/policy-templates",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "path-to-regexp": "^8.4.2"
  }
}
